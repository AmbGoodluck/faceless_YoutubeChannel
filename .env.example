# Copy this file to ".env" and fill in your real keys. NEVER commit the real .env.

# Anthropic — script generation. Get it at https://console.anthropic.com (Settings > API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Revid.ai — video generation. Growth plan required. Get it at https://www.revid.ai/account
REVID_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — a public URL Revid will POST the finished video to.
# Leave blank to poll status manually instead.
REVID_WEBHOOK_URL=
