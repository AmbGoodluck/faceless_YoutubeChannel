# Copy this file to ".env" and fill in your key. NEVER commit the real .env.

# Google Gemini — script generation. FREE, no credit card.
# Get it at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube upload uses OAuth, NOT a key here:
#   put client_secret.json in the repo root (see README step 5).
# Edge TTS and Pollinations need no keys at all.

# OPTIONAL — Slack notifications (daily script + video link land in a channel).
# Create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# CLOUD MODE (GitHub Actions) — Google Drive + YouTube headless auth.
# Mint these once with: python src/get_google_token.py  (see cloud/CLOUD_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GDRIVE_FOLDER_ID=

# AI VIDEO (fal.ai) — only needed if config.VIDEO_MODE = "ai" (paid, ~cents per clip).
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=
